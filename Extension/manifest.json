{
  "manifest_version": 3,
  "name": "InsightTube AI",
  "version": "1.0",
  "description": "AI assistant for YouTube",

  "permissions": [],

  "host_permissions": [
    "https://www.youtube.com/*"
  ],

  "web_accessible_resources": [
    {
      "resources": [
        "index.html",
        "styles.css",
        "script.js",
        "assets/*"
      ],
      "matches": [
        "https://www.youtube.com/*"
      ]
    }
  ],

  "content_scripts": [
    {
      "matches": [
        "https://www.youtube.com/*"
      ],
      "js": [
        "content.js"
      ]
    }
  ]
}